# ============================================================
# GeoIntent Classifier — Variables de Entorno
# Copia este archivo como .env y ajusta los valores
# ============================================================

# Puertos
BACKEND_PORT=8000
FRONTEND_PORT=80

# Rutas del modelo (dentro del contenedor)
MODEL_PATH=models/saved/best_model.pkl
ENCODER_PATH=models/saved/label_encoder.pkl

# Entorno
ENVIRONMENT=development   # development | production

# CORS (separado por comas)
ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000
